@model Dentcare.Models.Patient

<div class="signup-page">

    <div class="signup-box">

        <!-- LEFT SIDE -->
        <div class="signup-form">

            <h2>Sign Up</h2>

            <p>Create an account to start booking your dental appointment.</p>

            <button class="google-btn">
                <img src="https://developers.google.com/identity/images/g-logo.png" width="18">
                Sign up with Google
            </button>

            <div class="divider">or sign up using email</div>

            <form method="post">

                <input type="email" name="Email" placeholder="Email" required />

                <input type="password" name="Password" placeholder="Password" required />

                <button type="submit" class="signup-submit">
                    Continue
                </button>

            </form>

            <p class="login-text">
                Already have an account? <a href="#">Sign in</a>
            </p>

        </div>

        <!-- RIGHT SIDE -->
        <div class="signup-design"></div>

    </div>

</div>